# Supabase 配置 - 股票数据
# 在 Supabase Dashboard -> Settings -> API 中获取
VITE_SUPABASE_STOCK_URL=https://your-stock-project-id.supabase.co
VITE_SUPABASE_STOCK_ANON_KEY=your-stock-anon-key-here

# Supabase 配置 - 财经资讯
VITE_SUPABASE_NEWS_URL=https://your-news-project-id.supabase.co
VITE_SUPABASE_NEWS_ANON_KEY=your-news-anon-key-here

# 可选：用于批量导入脚本的服务端 Key
# 若未提供，导入脚本会退化使用 VITE_SUPABASE_NEWS_ANON_KEY
SUPABASE_NEWS_SERVICE_ROLE_KEY=your-news-service-role-key-here
SUPABASE_STOCK_SERVICE_ROLE_KEY=your-stock-service-role-key-here

# 智能选股 AI 代理配置
# 推荐默认走同源代理，前端只需要知道代理路径即可
VITE_AI_SCREENER_USE_PROXY=true
VITE_AI_SCREENER_PROXY_PATH=/api/ai/screener

# 如确实需要前端直连兼容 OpenAI 接口，可补充以下可公开变量
VITE_AI_SCREENER_BASE_URL=
VITE_AI_SCREENER_API_KEY=
VITE_AI_SCREENER_MODEL=
VITE_AI_SCREENER_PATH=/chat/completions

# 服务端私有变量，供 Vercel / Node 代理使用
AI_SCREENER_BASE_URL=
AI_SCREENER_API_KEY=
AI_SCREENER_MODEL=
AI_SCREENER_PATH=/chat/completions
