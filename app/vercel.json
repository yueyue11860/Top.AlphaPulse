{
  "crons": [
    {
      "path": "/api/picker-alert/run",
      "schedule": "30 7 * * 1-5"
    },
    {
      "path": "/api/picker-alert/run",
      "schedule": "0 12 * * 1-5"
    }
  ],
  "routes": [
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}